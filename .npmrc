# Hoist everything so Metro (apps/mobile) can resolve the long tail of
# transitive deps that Expo / RN packages import inline. metro.config.js sets
# disableHierarchicalLookup: true, so Metro only looks in the workspace + app
# node_modules — not pnpm's nested store — so pnpm must flatten like npm/yarn.
public-hoist-pattern[]=*

# React is unified to a single version across the monorepo via a pnpm override
# in the root package.json (react / react-dom / @types/react). It is NOT pinned
# here: react-native 0.85.3 requires react ^19.2.3 while apps/web pinned 19.2.0,
# and Next's production build pulls a duplicate React into its bundle (styled-jsx
# / radix peer-link to the second copy → the "workStore" prerender invariant)
# whenever two React versions coexist in one pnpm store. The override collapses
# them to 19.2.3 (a patch bump for web; Next 16.2.6 supports it) so there is only
# one React. See the root package.json `pnpm.overrides`.

# Tolerate flaky registry edges (single-tarball ECONNRESETs on large RN/Expo
# packages exhaust the default 2-retry budget mid-install).
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
