# =============================================================================
# VACATION PRICE TRACKER — PRODUCTION configuration (self-hosted stack)
# =============================================================================
# Copy to .env.prod on the prod host and fill in real secrets. Consumed by
# infra/docker-compose.prod.yml (project: vpt-prod). NEVER commit .env.prod.
#
#   cp .env.prod.example .env.prod
#   # edit .env.prod
#   pnpm prod:up
#   pnpm prod:db:migrate
# -----------------------------------------------------------------------------

ENVIRONMENT=production

# --- DATABASE ---
# POSTGRES_PASSWORD seeds the Postgres + Temporal containers. DATABASE_URL is
# what the api/worker connect with — keep the password in sync.
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgresql+asyncpg://postgres:change-me-strong-db-password@db:5432/vacation_tracker

# --- SECURITY ---
# openssl rand -hex 32
SECRET_KEY=change-me-openssl-rand-hex-32

# --- AUTH (GOOGLE OAUTH) ---
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- PUBLIC URLS / CORS ---
# Single public web origin (Cloudflare Tunnel / custom domain). BACKEND_URL is
# baked into the web image as NEXT_PUBLIC_API_URL.
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://api.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com

# --- LLM (GROQ) ---
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL=openai/gpt-oss-120b

# --- ADMIN SQL DEBUG ENDPOINT (POST /v1/admin/sql) ---
# Token MUST be >= 32 chars or the endpoint stays disabled. openssl rand -hex 32.
# Point ADMIN_QUERY_DATABASE_URL at a dedicated read-only role (vpt_query) when
# available; leave blank to reuse DATABASE_URL.
ADMIN_QUERY_TOKEN=change-me-openssl-rand-hex-32-min-32-chars
ADMIN_QUERY_DATABASE_URL=

# --- TEMPORAL ---
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=vacation-price-tracker-tasks

# --- REDIS ---
REDIS_URL=redis://redis:6379/0

# --- OBSERVABILITY (LANGFUSE — LLM/MCP tracing; blank disables) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://us.cloud.langfuse.com
LANGFUSE_ENVIRONMENT=production
