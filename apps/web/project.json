{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "web",
  "projectType": "application",
  "sourceRoot": "apps/web/src",
  "tags": ["scope:web", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.next"],
      "cache": true,
      "options": {
        "command": "next build",
        "cwd": "apps/web",
        "forwardAllArgs": false
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node server.js",
        "cwd": "apps/web",
        "forwardAllArgs": false
      },
      "configurations": {
        "development": {
          "command": "next dev --port 3000"
        }
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start --port 3000",
        "cwd": "apps/web",
        "forwardAllArgs": false
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default"],
      "options": {
        "command": "pnpm biome lint .",
        "cwd": "apps/web",
        "forwardAllArgs": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default"],
      "options": {
        "command": "pnpm tsc --noEmit",
        "cwd": "apps/web",
        "forwardAllArgs": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default"],
      "options": {
        "command": "NODE_NO_WARNINGS=1 pnpm jest --watchAll=false",
        "cwd": "apps/web",
        "forwardAllArgs": false
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["default"],
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "commands": [
          "NODE_NO_WARNINGS=1 pnpm jest --watchAll=false --coverage",
          "node ../../scripts/lcov-reroot.mjs coverage/lcov.info apps/web/"
        ],
        "parallel": false,
        "cwd": "apps/web",
        "forwardAllArgs": false
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm biome format --write .",
        "cwd": "apps/web",
        "forwardAllArgs": false
      }
    }
  }
}
