{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      },
      "a11y": {
        "useSemanticElements": "off",
        "useAriaPropsSupportedByRole": "off",
        "noStaticElementInteractions": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "bracketSpacing": true
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/*.css",
      "!**/.next",
      "!**/node_modules",
      "!**/out",
      "!**/coverage",
      "!**/.pnpm-store",
      "!**/playwright-report",
      "!**/test-results"
    ]
  }
}
