{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "ios": "expo run:ios",
    "ios:go": "expo start --ios",
    "android": "expo run:android",
    "android:go": "expo start --android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "expo lint",
    "test": "find lib components -path '*/__tests__/*' \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.cjs' \\) -print0 2>/dev/null | xargs -0 node --import tsx --test",
    "test:coverage": "mkdir -p coverage && find lib components -path '*/__tests__/*' \\( -name '*.test.ts' -o -name '*.test.tsx' -o -name '*.test.cjs' \\) -print0 2>/dev/null | xargs -0 node --import tsx --test --experimental-test-coverage --test-coverage-include='lib/**' --test-reporter=lcov --test-reporter-destination=coverage/mobile-unit.info --test-reporter=spec --test-reporter-destination=stdout",
    "web:build": "EXPO_PUBLIC_E2E_MODE=1 expo export --platform web --output-dir dist-web --clear"
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.1",
    "@expo/metro-runtime": "~57.0.3",
    "@react-native-community/netinfo": "12.0.1",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.4",
    "expo-auth-session": "~57.0.2",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-font": "~57.0.0",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-secure-store": "~57.0.0",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-updates": "~57.0.6",
    "expo-web-browser": "~57.0.0",
    "lucide-react-native": "^1.23.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.5",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.10.0",
    "semver": "^7.8.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@react-native/metro-config": "0.86.0",
    "@testing-library/react-native": "^14.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.8",
    "babel-preset-expo": "~57.0.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~57.0.0",
    "react-test-renderer": "19.2.3",
    "tsx": "^4.23.0",
    "typescript": "~6.0.3"
  }
}
